{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": "src",
    "paths": {
      "components/*": [
        "components/*"
      ],
      "hooks/*": [
        "hooks/*"
      ],
      "constants/*": [
        "constants/*"
      ],
      "assets/*": [
        "assets/*"
      ],
      "app/*": [
        "app/*"
      ],
      "utils/*": [
        "utils/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "src/expo-env.d.ts",
    "expo-env.d.ts"
  ]
}
